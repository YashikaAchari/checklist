{
  "expo": {
    "name": "FlyReady",
    "slug": "flyready",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "flyready",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Scan drone QR codes and capture flight photos",
        "NSPhotoLibraryUsageDescription": "Attach photos to flight records",
        "NSLocationWhenInUseUsageDescription": "Tag flight location and fetch local weather",
        "NSMicrophoneUsageDescription": "Record video clips of flight issues"
      },
      "bundleIdentifier": "com.emergent.flightops.mjo30p"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0C447C"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ],
      "package": "com.emergent.flightops.mjo30p"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0C447C"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Scan drone QR codes and capture flight photos"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Tag flight location and fetch local weather"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Attach photos to flight records"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
